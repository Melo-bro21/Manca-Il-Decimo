# =========================================================
# SERVER
# =========================================================

NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:8100


# =========================================================
# DATABASE POSTGRESQL
# Inserire i dati reali esclusivamente nel file backend/.env
# =========================================================

DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME?schema=public


# =========================================================
# AUTENTICAZIONE
# Generare una stringa lunga e casuale nel vero .env
# =========================================================

JWT_SECRET=INSERISCI_UN_SECRET_LUNGO_E_CASUALE
JWT_EXPIRES_IN=7d


# =========================================================
# EMAIL
# Lasciare EMAIL_ENABLED=false finché SMTP non è configurato
# =========================================================

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Manca il Decimo <no-reply@mancaildecimo.local>"


# =========================================================
# STRIPE - SOLO MODALITÀ TEST DURANTE LO SVILUPPO
# Non inserire mai questi valori nel repository Git
# =========================================================

STRIPE_SECRET_KEY=sk_test_INSERISCI_LA_CHIAVE_TEST
STRIPE_WEBHOOK_SECRET=whsec_INSERISCI_IL_SECRET_DEL_WEBHOOK